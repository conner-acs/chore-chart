# Test configuration for ./test.sh — copy to `.env.test` and fill in.
# `.env.test` is gitignored; this example file is safe to commit.

# Deployed REST API base URL (no trailing slash). From `serverless deploy` output
# or the `HttpApiUrl` stack output.
API=https://your-api-id.execute-api.us-east-1.amazonaws.com

# --- Auth: choose ONE path ---
# (a) Real login — set both to a known user's credentials:
SAFEDAY_EMAIL=
SAFEDAY_PASSWORD=
# (b) Or leave the two above blank and the script mints a token locally for
#     SAFEDAY_USER_ID, signed with SAFEDAY_JWT_SECRET (must equal the deployed
#     `secretKey` in Secrets Manager). Handy for the migrated users whose
#     plaintext passwords aren't in the dump.
SAFEDAY_JWT_SECRET=REPLACE_ME
SAFEDAY_USER_ID=d53f5b70-0a39-4c72-9af6-cdde6941b8cd

# Shared webhook secret — must equal the deployed `webhookSecret` in Secrets Manager.
WEBHOOK_SECRET=REPLACE_ME

# A site_token the auth'd user can access, and a valid Nx camera UUID, for the
# webhook-create + decision flow.
SAFEDAY_SITE_TOKEN=acs-child-centre
SAFEDAY_CAMERA_ID={b7e8f1a2-3c4d-5e6f-7a8b-9c0d1e2f3a4b}

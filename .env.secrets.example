# Secret values for scripts/deploy-profile.sh — copy to `.env.secrets` and fill in.
# `.env.secrets` is gitignored; this example is safe to commit.
#
# Any value left blank is handled as follows by the deploy script:
#   SECRET_KEY, WEBHOOK_SECRET            -> auto-generated (openssl rand -hex 32)
#   NX_CREDENTIAL_ENCRYPTION_KEY (blank)  -> Nx calls will 502 (decrypt can't run)
#   MAILTRAP_API_TOKEN (blank)            -> email sending is a no-op

# JWT signing key (HS256). Any high-entropy string. Leave blank to auto-generate.
SECRET_KEY=

# Shared secret for POST /api/v1/webhooks/alert (X-Webhook-Secret). Leave blank to auto-generate.
WEBHOOK_SECRET=

# Fernet key that decrypts each site's stored Nx Witness password. MUST be the
# same key the passwords were encrypted with (e.g. when migrating existing data).
# Generate a fresh one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NX_CREDENTIAL_ENCRYPTION_KEY=

# Mailtrap API token for invite emails (optional; blank disables email).
MAILTRAP_API_TOKEN=

TEST_EMAIL_TO=
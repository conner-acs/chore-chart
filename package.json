{
  "name": "safeday-serverless",
  "version": "1.0.0",
  "description": "SafeDay childcare alert-triage backend, transposed from FastAPI to Serverless Framework (Lambda + API Gateway + DynamoDB).",
  "type": "module",
  "scripts": {
    "deploy": "serverless deploy",
    "remove": "serverless remove",
    "logs": "serverless logs",
    "migrate": "node scripts/migrate.js",
    "migrate:local": "node scripts/migrate.js --endpoint http://localhost:8000"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-sesv2": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "bcryptjs": "^2.4.3",
    "fernet": "^0.4.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "serverless": "^4.38.0"
  }
}
